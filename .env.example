# Stead — environment template. Copy to .env and fill in your own values.
# .env is gitignored. NEVER commit real keys.

# Claude — "Ask Stead" + the agent
ANTHROPIC_API_KEY=
# Optional model override for Ask Stead (default: claude-sonnet-4-6)
STEAD_MODEL=

# Neon Postgres — Ruby's day + the consent ledger. If unset, falls back to local SQLite.
DATABASE_URL=

# Vapi — real outbound phone calls
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
# The number the agent dials (E.164, e.g. +1XXXXXXXXXX). In the demo this is the "restaurant".
VAPI_TARGET_PHONE=
# Vapi-hosted call model (must be a Vapi-allow-listed id, e.g. claude-sonnet-4-6)
STEAD_VAPI_MODEL=

# Call voice: "vapi" (built-in, no extra billing) or "11labs" (ElevenLabs cloned voice)
STEAD_VOICE_PROVIDER=vapi
STEAD_VAPI_VOICE=Elliot
# ElevenLabs (only needed if STEAD_VOICE_PROVIDER=11labs)
ELEVENLABS_API_KEY=
STEAD_VOICE_ID=

# MARS robot over rosbridge, e.g. ws://<robot-ip>:9090
ROSBRIDGE_URL=

# Langfuse — optional external tracing (local audit is always on)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
